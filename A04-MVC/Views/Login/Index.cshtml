@model A04_MVC.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="auth-wrapper">
    <div style="width: 100%; max-width: 460px;">

        <div style="text-align:center; margin-bottom: 2rem;">
            <h1 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:1.75rem;color:#07152E;letter-spacing:-.4px;margin:0;">Home Inventory</h1>
            <p style="color:#94A3B8;font-size:.9rem;margin:.4rem 0 0;">Sign in to manage your catalog</p>
        </div>

        <div class="card">
            <div class="card-body" style="padding: 2.25rem !important;">

                @if (TempData["RegistrationSuccess"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["RegistrationSuccess"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Index" method="post">
                    <div asp-validation-summary="All" class="validation-summary-errors"></div>
                    <div class="form-group mb-4">
                        <label asp-for="Username" class="control-label"></label>
                        <div style="position:relative;">
                            <span style="position:absolute;left:.875rem;top:50%;transform:translateY(-50%);color:#94A3B8;">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.8" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
                            </span>
                            <input asp-for="Username" class="form-control" placeholder="Enter your username" style="padding-left:2.75rem !important;" />
                        </div>
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Password" class="control-label"></label>
                        <div style="position:relative;">
                            <span style="position:absolute;left:.875rem;top:50%;transform:translateY(-50%);color:#94A3B8;">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.8" /><path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
                            </span>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" style="padding-left:2.75rem !important;" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <button type="submit" class="btn btn-primary w-100" style="padding:.8rem !important; font-size:.95rem !important;">
                            Sign In
                        </button>
                    </div>
                </form>

                <div class="text-center" style="padding-top:.75rem;border-top:1px solid #E2E8F0;margin-top:.5rem;">
                    <p style="margin:0;font-size:.875rem;color:#94A3B8;">
                        Don't have an account?
                        <a asp-action="Register" style="color:#1A56DB;font-weight:600;">Create one here</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
