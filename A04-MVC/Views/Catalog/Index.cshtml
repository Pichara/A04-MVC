@model A04_MVC.Models.ItemListViewModel
@{
    ViewData["Title"] = "My Inventory";
}

<div style="padding-top: 1.5rem;">

    <div class="page-header">
        <div>
            <h2>My Inventory</h2>
            <p>Manage and track all your home items</p>
        </div>
        <a asp-action="Create" class="btn btn-primary" style="display:flex;align-items:center;gap:.5rem;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
            </svg>
            Add Item
        </a>
    </div>

    @if (Model.Items == null || !Model.Items.Any())
    {
        <div style="text-align:center;padding:4rem 2rem;background:#fff;border:1px solid #E2E8F0;">
            <div style="width:64px;height:64px;background:#EBF2FF;margin:0 auto 1.25rem;display:flex;align-items:center;justify-content:center;">
                <svg width="30" height="30" fill="none" viewBox="0 0 24 24">
                    <path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" stroke="#1A56DB" stroke-width="1.8" />
                    <path d="M16 3H8L6 7h12l-2-4z" stroke="#1A56DB" stroke-width="1.8" stroke-linejoin="round" />
                </svg>
            </div>
            <h3 style="font-weight:600;color:#111827;font-size:1.1rem;margin-bottom:.5rem;">No items yet</h3>
            <p style="color:#6B7280;font-size:.9rem;margin-bottom:1.5rem;">Add your first inventory item to get started.</p>
            <a asp-action="Create" class="btn btn-primary">Add Item</a>
        </div>
    }
    else
    {
        <div style="background:#fff;border:1px solid #E2E8F0;overflow:hidden;">
            <div class="table-responsive">
                <table class="table" style="margin:0;">
                    <thead>
                        <tr>
                            <th>Item Name</th>
                            <th>Date Purchased</th>
                            <th>Price</th>
                            <th>Category</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td style="font-weight:600;color:#111827;">
                                    @item.Item
                                </td>
                                <td style="color:#6B7280;">
                                    @item.DateBought.ToString("MMM dd, yyyy")
                                </td>
                                <td style="font-weight:600;">
                                    $@item.Price.ToString("F2")
                                </td>
                                <td style="color:#6B7280;">
                                    @(item.Category?.CategoryName ?? "—")
                                </td>
                                <td style="text-align:right;">
                                    <div style="display:flex;gap:.5rem;justify-content:flex-end;">
                                        <a asp-action="Edit"
                                           asp-route-id="@($"{item.UserId}|{item.Item}|{item.CategoryId}")"
                                           class="btn btn-outline-primary btn-sm">Edit</a>

                                        <a asp-action="Delete"
                                           asp-route-id="@($"{item.UserId}|{item.Item}|{item.CategoryId}")"
                                           class="btn btn-sm"
                                           style="background:#FEF2F2;color:#B42318;border:1px solid #FECACA;font-weight:600;">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="padding:.75rem 1.25rem;background:#F9FAFB;border-top:1px solid #E2E8F0;display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:.85rem;color:#6B7280;">
                    @(Model.Items?.Count() ?? 0) item@((Model.Items?.Count() ?? 0) == 1 ? "" : "s")
                </span>
                <span style="font-size:.85rem;color:#6B7280;">
                    Total Value: <span style="color:#111827;font-weight:600;">
                        $@(Model.Items?.Sum(i => i.Price).ToString("F2") ?? "0.00")
                    </span>
                </span>
            </div>
        </div>
    }
</div>