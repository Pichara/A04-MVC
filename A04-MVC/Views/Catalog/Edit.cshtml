@model A04_MVC.Models.ItemCreateViewModel
@{
    ViewData["Title"] = "Edit Item";
}

<div style="max-width: 620px; margin: 2rem auto;">

    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.75rem;">
        <a asp-action="Index" style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;background:#fff;border:1.5px solid #E2E8F0;border-radius:9px;color:#475569;transition:all .2s;text-decoration:none;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
        <div>
            <h2 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:1.5rem;color:#07152E;margin:0;letter-spacing:-.3px;">Edit Item</h2>
            <p style="color:#94A3B8;font-size:.85rem;margin:.2rem 0 0;">Update the details for this inventory item</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div class="form-group mb-4">
                    <label asp-for="Item" class="control-label"></label>
                    <input asp-for="Item" class="form-control" />
                    <span asp-validation-for="Item" class="text-danger"></span>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
                    <div class="form-group mb-4">
                        <label asp-for="DateBought" class="control-label"></label>
                        <input asp-for="DateBought" class="form-control" type="date" />
                        <span asp-validation-for="DateBought" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Price" class="control-label"></label>
                        <div style="position:relative;">
                            <span style="position:absolute;left:.875rem;top:50%;transform:translateY(-50%);color:#94A3B8;font-weight:600;font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;">$</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" style="padding-left:2rem !important;" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-5">
                    <label asp-for="CategoryId" class="control-label"></label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-control">
                        <option value="">— Select a Category —</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div style="display:flex;gap:.75rem;padding-top:1.25rem;border-top:1px solid #E2E8F0;">
                    <button type="submit" class="btn btn-primary" style="flex:1;">
                        Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
