@model A04_MVC.Models.ItemCatalog
@{
    ViewData["Title"] = "Delete Item";
}

<div class="container" style="max-width: 600px; margin-top: 50px;">
    <div class="card">
        <div class="card-header">
            <h2>Delete Item</h2>
        </div>
        <div class="card-body">
            <div class="alert alert-danger">
                Are you sure you want to delete this item?
            </div>

            <dl class="row">
                <dt class="col-sm-3">Item:</dt>
                <dd class="col-sm-9">@Model.Item</dd>

                <dt class="col-sm-3">Date Purchased:</dt>
                <dd class="col-sm-9">@Model.DateBought.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Price:</dt>
                <dd class="col-sm-9">$@Model.Price.ToString("F2")</dd>

                <dt class="col-sm-3">Category:</dt>
                <dd class="col-sm-9">@(Model.Category?.CategoryName ?? "N/A")</dd>
            </dl>

            <form asp-action="DeleteConfirmed" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@($"{Model.UserId}|{Model.Item}|{Model.CategoryId}")" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
