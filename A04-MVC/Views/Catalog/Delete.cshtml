@model A04_MVC.Models.ItemCatalog
@{
    ViewData["Title"] = "Delete Item";
}

<div style="max-width: 560px; margin: 2rem auto;">

    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.75rem;">
        <a asp-action="Index" style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;background:#fff;border:1.5px solid #E2E8F0;border-radius:9px;color:#475569;transition:all .2s;text-decoration:none;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
        <div>
            <h2 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:1.5rem;color:#07152E;margin:0;letter-spacing:-.3px;">Delete Item</h2>
            <p style="color:#94A3B8;font-size:.85rem;margin:.2rem 0 0;">This action cannot be undone</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">

            <!-- Warning Banner -->
            <div style="background:#FEF2F2;border:1.5px solid #FECACA;border-radius:10px;padding:1rem 1.25rem;display:flex;align-items:flex-start;gap:.875rem;margin-bottom:1.75rem;">
                <div style="flex-shrink:0;width:36px;height:36px;background:#FEE2E2;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                        <path d="M12 9v4M12 17h.01" stroke="#DC2626" stroke-width="2" stroke-linecap="round" />
                        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="#DC2626" stroke-width="1.8" stroke-linejoin="round" />
                    </svg>
                </div>
                <div>
                    <p style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;color:#991B1B;font-size:.9rem;margin:0 0 .2rem;">Confirm Deletion</p>
                    <p style="color:#B91C1C;font-size:.85rem;margin:0;">Are you sure you want to permanently delete this item from your inventory?</p>
                </div>
            </div>

            <!-- Item Details -->
            <div style="background:#F8FAFC;border:1px solid #E2E8F0;border-radius:10px;padding:1.25rem;margin-bottom:1.75rem;">
                <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:1.1rem;color:#07152E;margin:0 0 1rem;padding-bottom:.75rem;border-bottom:1px solid #E2E8F0;">Item Details</h3>
                <dl class="row" style="margin:0;">
                    <dt class="col-sm-4" style="border-bottom:none !important;">Item Name</dt>
                    <dd class="col-sm-8" style="border-bottom:none !important;font-weight:700;color:#07152E;">@Model.Item</dd>

                    <dt class="col-sm-4">Date Purchased</dt>
                    <dd class="col-sm-8">@Model.DateBought.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8" style="font-weight:700;color:#0D3B8E;">$@Model.Price.ToString("F2")</dd>

                    <dt class="col-sm-4" style="border-bottom:none !important;">Category</dt>
                    <dd class="col-sm-8" style="border-bottom:none !important;">
                        <span class="badge-category">@(Model.Category?.CategoryName ?? "N/A")</span>
                    </dd>
                </dl>
            </div>

            <!-- Actions -->
            <form asp-action="DeleteConfirmed" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@($"{Model.UserId}|{Model.Item}|{Model.CategoryId}")" />
                <div style="display:flex;gap:.75rem;">
                    <button type="submit" class="btn btn-danger" style="flex:1;">
                        Yes, Delete Item
                    </button>
                    <a asp-action="Index" class="btn btn-secondary" style="flex:1;text-align:center;">
                        No, Keep It
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
